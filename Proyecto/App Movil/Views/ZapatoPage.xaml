<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMovil.Views.ZapatoPage">

    <StackLayout Padding="20">

        <Label Text="Zapatos Biónicos"
               FontSize="24"
               HorizontalOptions="Center"/>

        <CollectionView ItemsSource="{Binding ListaZapatos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Margin="5">
                        <StackLayout>

                            <Label Text="{Binding Nombre}" FontAttributes="Bold"/>
                            <Label Text="{Binding Descripcion}"/>
                            <Label Text="{Binding NivelBateria, StringFormat='Batería: {0}%'}"/>
                            <Label Text="{Binding Estado, StringFormat='Estado: {0}'}"/>

                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</ContentPage>
